{
  "name": "voiceflow",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/larosafrancesco289/voiceflow.git"
  },
  "homepage": "https://github.com/larosafrancesco289/voiceflow",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh",
    "build": "cd apps/desktop && bun run tauri build",
    "build:desktop": "cd apps/desktop && bun run build",
    "build:server": "./scripts/build-server.sh",
    "desktop": "cd apps/desktop && bun run dev",
    "python": "cd python && uv run python -m voiceflow_server.server",
    "test": "bun run test:desktop && bun run test:python",
    "test:desktop": "cd apps/desktop && bun run test",
    "test:python": "cd python && uv run pytest",
    "check": "bun run build:desktop && bun run test",
    "test:e2e:shortcut": "./scripts/e2e-shortcut.sh"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
